// CH32V003F4U6 platform for Renode.
//
// Memory map per the ch32v003 reference manual (matches ldscripts/ch32v003.ld):
//   Flash   : 0x00000000  16 KiB   (also aliased at 0x08000000 internally)
//   SRAM    : 0x20000000   2 KiB
//
// Each PythonPeripheral with non-trivial behavior lives in its own .repl
// under peripherals/ — Renode's `using "./..."` resolves relative to this
// file. PythonPeripheral filename: would resolve only against Renode's
// install dir, which is why we keep the scripts inline inside per-peripheral
// .repls rather than as sibling .py files.

using "./peripherals/rcc.repl"
using "./peripherals/adc1.repl"
using "./peripherals/i2c1.repl"
using "./peripherals/pfic.repl"

cpu: CPU.RiscV32 @ sysbus
    // Renode doesn't have a literal rv32ec — rv32imc is the smallest
    // superset it accepts. Zicsr is required because ch32fun's startup
    // writes mtvec; Zifencei rounds out the standard baseline.
    cpuType: "rv32imc_zicsr_zifencei"
    privilegedArchitecture: PrivilegedArchitecture.Priv1_10

flash: Memory.MappedMemory @ sysbus 0x00000000
    size: 0x4000

sram: Memory.MappedMemory @ sysbus 0x20000000
    // Real chip has 2 KiB; rounded up to Renode's 4 KiB minimum page size.
    // Firmware only touches the low 0x800 bytes; the rest is invisible.
    size: 0x1000

// --- Passive memory stubs for regions firmware writes but never reads back ---

flashIf: Memory.ArrayMemory @ sysbus 0x40022000
    size: 0x400

afio:  Memory.ArrayMemory @ sysbus 0x40010000
    size: 0x400
exti:  Memory.ArrayMemory @ sysbus 0x40010400
    size: 0x400
gpioA: Memory.ArrayMemory @ sysbus 0x40010800
    size: 0x400
gpioC: Memory.ArrayMemory @ sysbus 0x40011000
    size: 0x400
gpioD: Memory.ArrayMemory @ sysbus 0x40011400
    size: 0x400
