// CH32V003F4U6 platform for Renode.
//
// Memory map per the ch32v003 reference manual (matches ldscripts/ch32v003.ld):
//   Flash   : 0x00000000  16 KiB   (also aliased at 0x08000000 internally)
//   SRAM    : 0x20000000   2 KiB
//
// Peripherals: only the regions the syzygy-dna firmware actually touches.
// Plain RW stubs use Memory.ArrayMemory (no page-size constraint). RCC and
// ADC1 have active behavior (auto-RDY / auto-EOC) and inline a small
// IronPython script — Renode's PythonPeripheral filename: resolver is
// hard-wired to its install dir, so we keep the scripts here rather than
// in a sibling .py file.
//
// I2C1 is currently a memory stub — the next step replaces it with a real
// controller model that exposes start/stop/byte-transfer hooks to pytest.

cpu: CPU.RiscV32 @ sysbus
    // Renode doesn't have a literal rv32ec — rv32imc is the smallest
    // superset it accepts. Zicsr is required because ch32fun's startup
    // writes mtvec; Zifencei rounds out the standard baseline.
    cpuType: "rv32imc_zicsr_zifencei"
    privilegedArchitecture: PrivilegedArchitecture.Priv1_10

flash: Memory.MappedMemory @ sysbus 0x00000000
    size: 0x4000

sram: Memory.MappedMemory @ sysbus 0x20000000
    // Real chip has 2 KiB; rounded up to Renode's 4 KiB minimum page size.
    // Firmware only touches the low 0x800 bytes; the rest is invisible.
    size: 0x1000

// --- Clock / system ---------------------------------------------------------
// RCC stub: mirrors the EN bits (HSION/HSEON/PLLON) into their RDY
// counterparts so ch32fun's clock spin-loops complete immediately.
// Everything else is plain read-back storage.

rcc: Python.PythonPeripheral @ sysbus 0x40021000
    size: 0x400
    initable: true
    script: '''
if request.IsInit:
    regs = {}
elif request.IsRead:
    request.Value = regs.get(request.Offset, 0)
elif request.IsWrite:
    val = request.Value
    if request.Offset == 0x00:       # CTLR: HSION/HSEON/PLLON -> *RDY
        if val & (1 << 0):  val |= (1 << 1)
        if val & (1 << 16): val |= (1 << 17)
        if val & (1 << 24): val |= (1 << 25)
    elif request.Offset == 0x04:     # CFGR0: SW -> SWS (clock-switch status)
        val = (val & ~(0b11 << 2)) | ((val & 0b11) << 2)
    regs[request.Offset] = val
'''

flashIf: Memory.ArrayMemory @ sysbus 0x40022000
    size: 0x400

// --- GPIO + alt-function mux ------------------------------------------------

afio:  Memory.ArrayMemory @ sysbus 0x40010000
    size: 0x400
exti:  Memory.ArrayMemory @ sysbus 0x40010400
    size: 0x400
gpioA: Memory.ArrayMemory @ sysbus 0x40010800
    size: 0x400
gpioC: Memory.ArrayMemory @ sysbus 0x40011000
    size: 0x400
gpioD: Memory.ArrayMemory @ sysbus 0x40011400
    size: 0x400

// --- ADC --------------------------------------------------------------------
// ADC1 stub: RSTCAL/CAL bits in CTLR2 are self-clearing (firmware spins on
// them). SWSTART triggers EOC in STATR. RDATAR returns a fixed raw count
// — 662 maps to ~2135 mV -> I2C address 0x35 (index 5 in ga_adc.cpp's
// nominal table). Tests can rewrite this via the Renode monitor before
// the firmware reaches resolve_geographical_address.

adc1: Python.PythonPeripheral @ sysbus 0x40012400
    size: 0x400
    initable: true
    script: '''
if request.IsInit:
    regs = {}
    raw_count = 662  # ~2135 mV -> I2C 0x35
elif request.IsRead:
    if request.Offset == 0x4C:           # RDATAR
        request.Value = raw_count & 0x3FF
    else:
        request.Value = regs.get(request.Offset, 0)
elif request.IsWrite:
    val = request.Value
    if request.Offset == 0x08:           # CTLR2
        val &= ~(1 << 2)                 # CAL    self-clears
        val &= ~(1 << 3)                 # RSTCAL self-clears
        if val & (1 << 22):              # SWSTART -> EOC
            val &= ~(1 << 22)
            regs[0x00] = regs.get(0x00, 0) | (1 << 1)  # STATR.EOC
    regs[request.Offset] = val
'''

// --- I2C1 -------------------------------------------------------------------
// Models the CH32V003 I2C1 from the target's perspective.
//
// The firmware-visible registers live at the real offsets (CTLR1 etc.).
// Controller-side test injection happens through "magic" offsets in the
// upper half of the peripheral window (0x100..0x114) that real silicon
// doesn't use — write them from the test harness to drive START/RX/STOP
// and read 0x108 to pull TX bytes the firmware has staged.
//
// IRQ output is a software flag at the moment; the PFIC + HSP shim that
// dispatches it to the CPU lands in the next change. Tests currently
// invoke I2C1_EV_IRQHandler manually after each magic-register poke.

i2c1: Python.PythonPeripheral @ sysbus 0x40005400
    size: 0x400
    initable: true
    script: '''
# Real I2C1 register offsets (CH32V003 RM)
CTLR1, CTLR2, OADDR1, OADDR2 = 0x00, 0x04, 0x08, 0x0C
DATAR, STAR1, STAR2, CKCFGR  = 0x10, 0x14, 0x18, 0x1C

# Magic offsets for test-harness injection (no real-silicon meaning)
INJ_START, INJ_RX, INJ_TX     = 0x100, 0x104, 0x108
INJ_STOP, INJ_NACK            = 0x10C, 0x110
IRQ_STATE                     = 0x114   # read: bit0=EV, bit1=ER

# STAR1 / STAR2 flag bits
SB, ADDR, BTF, STOPF = 1<<0, 1<<1, 1<<2, 1<<4
RXNE, TXE            = 1<<6, 1<<7
BERR, ARLO, AF       = 1<<8, 1<<9, 1<<10
MSL, BUSY, TRA       = 1<<0, 1<<1, 1<<2

# CTLR1 / CTLR2 bits
PE, ACK, SWRST       = 1<<0, 1<<10, 1<<15
ITERREN, ITEVTEN, ITBUFEN = 1<<8, 1<<9, 1<<10

if request.IsInit:
    regs = {CTLR1: 0, CTLR2: 0, OADDR1: 0, OADDR2: 0,
            DATAR: 0, STAR1: 0, STAR2: 0, CKCFGR: 0}
    ev_irq = False
    er_irq = False

# ---------------- Firmware reads ----------------
elif request.IsRead and request.Offset < 0x100:
    off = request.Offset
    val = regs.get(off, 0)
    if off == STAR2:
        # ARM-style STAR1-then-STAR2 read sequence clears ADDR.
        regs[STAR1] = regs[STAR1] & ~ADDR
    elif off == DATAR:
        # Reading DATAR clears RXNE on the receive side.
        regs[STAR1] = regs[STAR1] & ~RXNE
    request.Value = val

# ---------------- Firmware writes ----------------
elif request.IsWrite and request.Offset < 0x100:
    off = request.Offset
    val = request.Value
    if off == CTLR1:
        if val & SWRST:
            regs[STAR1] = 0
            regs[STAR2] = 0
            regs[DATAR] = 0
        # Firmware clears STOPF via "read STAR1, write CTLR1".
        regs[STAR1] = regs[STAR1] & ~STOPF
        regs[CTLR1] = val
    elif off == DATAR:
        # Firmware staging a TX byte. Clears TXE; controller picks it up
        # via a read of INJ_TX.
        regs[DATAR] = val & 0xFF
        regs[STAR1] = regs[STAR1] & ~TXE
    elif off == STAR1:
        # Only AF/BERR/ARLO can be cleared by firmware (W0C semantics:
        # writing 0 clears, writing 1 leaves alone).
        clearable = AF | BERR | ARLO
        regs[STAR1] = (regs[STAR1] & ~clearable) | (regs[STAR1] & val & clearable)
    else:
        regs[off] = val
    # Recompute IRQ outputs after every register touch.
    ev_irq = bool(regs[CTLR2] & ITEVTEN and (regs[STAR1] & (ADDR | STOPF | BTF) or
                  (regs[CTLR2] & ITBUFEN and regs[STAR1] & (RXNE | TXE))))
    er_irq = bool(regs[CTLR2] & ITERREN and regs[STAR1] & (BERR | ARLO | AF))

# ---------------- Test-harness injection ----------------
elif request.IsWrite and request.Offset == INJ_START:
    # value bit 0 = R/W direction (1 = controller is reading)
    is_read = bool(request.Value & 1)
    regs[STAR1] = (regs[STAR1] & ~STOPF) | ADDR
    regs[STAR2] = BUSY | (TRA if is_read else 0)
elif request.IsWrite and request.Offset == INJ_RX:
    # Controller-side byte arriving at target. Latches into DATAR + RXNE.
    regs[DATAR] = request.Value & 0xFF
    regs[STAR1] = regs[STAR1] | RXNE
elif request.IsRead and request.Offset == INJ_TX:
    # Controller pulling a byte from the target. Whatever firmware last
    # wrote to DATAR is returned; mark TXE so the ISR is invited to
    # stage the next byte.
    request.Value = regs[DATAR] & 0xFF
    regs[STAR1] = regs[STAR1] | TXE
elif request.IsWrite and request.Offset == INJ_STOP:
    regs[STAR1] = regs[STAR1] | STOPF
    regs[STAR2] = 0
elif request.IsWrite and request.Offset == INJ_NACK:
    regs[STAR1] = regs[STAR1] | AF
elif request.IsRead and request.Offset == IRQ_STATE:
    request.Value = (1 if ev_irq else 0) | (2 if er_irq else 0)

# Refresh IRQ flags after injection too.
if request.IsWrite and INJ_START <= request.Offset <= INJ_NACK:
    ev_irq = bool(regs[CTLR2] & ITEVTEN and (regs[STAR1] & (ADDR | STOPF | BTF) or
                  (regs[CTLR2] & ITBUFEN and regs[STAR1] & (RXNE | TXE))))
    er_irq = bool(regs[CTLR2] & ITERREN and regs[STAR1] & (BERR | ARLO | AF))
'''

// --- Interrupt controller (PFIC / WCH-extended CLIC space) ------------------
// 0xE000E000-0xE000EFFF is the standard CLIC/NVIC area; WCH puts extra
// config regs at 0xE000F000. Until a real PFIC model exists, both are
// memory stubs — firmware can write NVIC enable bits, they just have no
// effect on interrupt delivery yet.

pfic:    Memory.ArrayMemory @ sysbus 0xE000E000
    size: 0x1000
pficCfg: Memory.ArrayMemory @ sysbus 0xE000F000
    size: 0x1000
